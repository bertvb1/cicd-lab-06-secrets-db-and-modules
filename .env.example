# Copy this file to .env (which is gitignored) before running `docker compose up`.
# Override the defaults for local development.
#
# This lab runs THREE Ignition gateways (local / test / production). Each gateway has
# its own admin credentials and its own API key. Local credentials are used
# at first login; test/production credentials are only needed when you click into
# those gateways' UIs.
#
# Leave the IGNITION_API_KEY_* lines EMPTY: scripts/setup.sh (via
# scripts/generate-api-keys.sh) generates a unique key per gateway on first
# run, writes the value here, and installs the matching token resource (hash
# only) into that gateway's config tree. Nothing key-related is committed —
# the token paths are gitignored, and the deploy workflow spares them on the
# gateway — so every clone gets its own working credentials, and this file
# never holds a real secret. For CI, copy the generated IGNITION_API_KEY_TEST
# / _PRODUCTION values into GitHub environment secrets named IGNITION_API_KEY
# on the lab-gateway-test / lab-gateway-production environments. See
# README.md for the full setup.

# ---- Local gateway (http://localhost:8088) ------------------------------
GATEWAY_ADMIN_USERNAME_LOCAL=admin
GATEWAY_ADMIN_PASSWORD_LOCAL=password
IGNITION_API_KEY_LOCAL=

# ---- Test gateway (http://localhost:8089) — deploy.yml target ------------
GATEWAY_ADMIN_USERNAME_TEST=admin
GATEWAY_ADMIN_PASSWORD_TEST=password
IGNITION_API_KEY_TEST=

# ---- Production gateway (http://localhost:8090) — deploy.yml target=production ------
GATEWAY_ADMIN_USERNAME_PRODUCTION=admin
GATEWAY_ADMIN_PASSWORD_PRODUCTION=password
IGNITION_API_KEY_PRODUCTION=

# ---- Backward-compat single key (optional) ------------------------------
# Older scripts/CI workflows that don't set a per-gateway key fall back to
# this. You can leave it unset; scan.sh will pick the right
# IGNITION_API_KEY_<GATEWAY> based on the --gateway flag.
# IGNITION_API_KEY=

# ---- Shared TimescaleDB sidecar ------------------------------------------
# One Postgres instance, three databases (ignition_local_development, ignition_test,
# ignition_production), and two logins: `ignition` (superuser — the TimescaleDB
# connection) and `reporting` (read-only — the TimescaleDB_Reports
# connection, created by db-init/ on first volume init).
#
# These values are rung 1 of the secrets ladder: env vars that anyone can
# `docker inspect` out of the containers. Part 1A of the lab moves them into
# files under secrets/ — keep the SAME values when you do (they match
# secrets/*.example): Postgres only sets passwords on first volume init, so
# a new value here would not change an existing database.
POSTGRES_USER=ignition
POSTGRES_PASSWORD=lab06-postgres-pw
REPORTING_PASSWORD=lab06-reporting-pw

# ---- GitHub Actions self-hosted runner ----------------------------------
# Auto-starts as part of `docker compose up -d`. The runner uses RUNNER_GITHUB_PAT
# (a GitHub Personal Access Token with `repo` scope) to fetch its own registration
# token, so you don't have to generate one manually. Both vars MUST be set for the
# runner container to register; otherwise it'll restart-loop with a 401 in its logs.
#
# Reuse the same `repo`-scope PAT you created in Lab 04 — just paste it into
# RUNNER_GITHUB_PAT below. (New here? github.com/settings/tokens → Generate new
# token (classic) → tick `repo` → copy the ghp_... value.)
#
# RUNNER_REPO_URL is your fork (not the upstream mustry-academy repo).
# RUNNER_GITHUB_PAT lives only in .env — never commit it.
RUNNER_REPO_URL=https://github.com/<your-github-user>/cicd-lab-06-secrets-db-and-modules
RUNNER_GITHUB_PAT=ghp_replace-me-with-a-pat-that-has-repo-scope
RUNNER_NAME=lab06-runner
